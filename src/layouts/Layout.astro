---
import '../styles/global.css';
import { Font } from 'astro:assets';

interface Props {
    title?: string;
    description?: string;
    canonical?: string;
}

const {
    title = 'Akash Pillai - Software Engineer',
    description = 'Akash Pillai is a software engineer based in Chicago who specializes in building things for the web.',
    canonical = 'https://akash.dev/',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonical} />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonical} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />

        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <Font cssVariable="--font-inter" preload />
        <Font cssVariable="--font-outfit" preload />
        <script defer data-domain="akash.dev" src="https://plausible.io/js/plausible.js"></script>
    </head>
    <body class="bg-primary-bg font-inter">
        <slot />
    </body>
</html>
