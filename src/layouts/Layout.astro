---
import '../styles/global.css';
import { Font } from 'astro:assets';
---
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Akash Pillai - Software Engineer</title>
        <meta name="description" content="Akash Pillai is a software engineer based in Chicago who specializes in building things for the web." />
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <Font cssVariable="--font-inter" preload />
        <Font cssVariable="--font-outfit" preload />
        <script defer data-domain="akash.dev" src="https://plausible.io/js/plausible.js"></script>
    </head>
    <body class="bg-primary-bg font-inter">
        <slot />
    </body>
</html>
