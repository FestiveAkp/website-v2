---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import MediaButton from '../components/MediaButton.astro';
import { Icon } from 'astro-icon/components';
---
<Layout>
    <section id="home" class="h-screen relative flex justify-center items-center">
        <div id="animated" class="flex justify-center">
            <div class="absolute lg:fixed top-0 left-0 mt-6 ml-8">
                <div class="h-2 w-40 rounded-sm bg-gray-600 hover:bg-gray-500 cursor-pointer" id="bar-home"></div>
                <div class="h-2 w-28 rounded-sm bg-gray-600 hover:bg-gray-500 cursor-pointer mt-2" id="bar-projects"></div>
            </div>
            <div id="content" class="px-6 max-w-3xl w-full mx-auto">
                <h1 class="text-6xl md:text-8xl font-outfit font-semibold text-primary whitespace-nowrap">Akash Pillai</h1>
                <p class="md:text-lg text-gray-200/90 mt-6">
                    I'm a software engineer based in Chicago, building full-stack web applications. Currently at
                    <a href="https://sproutsocial.com/" class="hover:underline text-emerald-400">Sprout Social</a>.
                </p>
                <div class="space-x-6 mt-8 border-t border-gray-700 pt-3">
                    <MediaButton title="GitHub" link="https://github.com/FestiveAkp" icon="mdi:github" />
                    <MediaButton title="LinkedIn" link="https://www.linkedin.com/in/akash-pillai-/" icon="mdi:linkedin" />
                    <MediaButton title="Email" link="mailto:akashp807@gmail.com" icon="mdi:email" />
                </div>
            </div>
            <button id="scroll-hint" class="absolute p-4 text-gray-300" style="bottom:7vh">
                <Icon name="mdi:chevron-down" class="w-6 h-6" />
            </button>
        </div>
    </section>

    <div class="pattern-cross-dots-sm h-8 text-gray-500"></div>

    <section id="projects" class="text-gray-200/90 p-6 pt-14">
        <div class="max-w-3xl mx-auto">
            <h2 class="text-3xl md:text-4xl font-outfit font-semibold border-b border-gray-700 pb-3">Featured Projects</h2>
            <div class="mt-8 flex flex-col justify-between space-y-8">
                <ProjectCard
                    title="AdventureList"
                    tools="Laravel – React"
                    description="A social travel diary to plan trips, log visits, and share adventures with friends."
                    view="https://adventurelist.app"
                    image="/adventurelist.png"
                    code="https://github.com/FestiveAkp/adventurelist"
                />
                <ProjectCard
                    title="testfile.io"
                    tools="Clojure"
                    description="Public API for retrieving dummy files of various sizes and filetypes for testing programs and networks."
                    view="http://testfile-io.fly.dev/"
                    code="https://github.com/FestiveAkp/testfile.io"
                />
                <ProjectCard
                    title="Gradient Clock"
                    tools="React – Next.js"
                    description="A beautifully simple date and time display in front of a colorful moving gradient."
                    view="https://akash.dev/clock/"
                    code="https://github.com/FestiveAkp/clock"
                />
                <ProjectCard
                    title="Smoke Detector Beeps"
                    tools="HTML – Alpine.js"
                    description="Simulate the comforting sounds of several low-battery smoke detectors."
                    view="http://akash.dev/beeps/"
                    code="https://github.com/FestiveAkp/beeps"
                />
            </div>
            <div class="mt-10 border-t border-gray-700 pt-6">
                <a href="/projects" class="inline-flex items-center gap-1 text-emerald-400 hover:underline">
                    See all projects <Icon name="mdi:arrow-right" class="w-4 h-4" />
                </a>
            </div>
        </div>
    </section>

    <footer class="h-2 bg-primary mt-24"></footer>
</Layout>

<script>
    const jumpTo = (elem: string) => document.querySelector(elem)!.scrollIntoView({ behavior: 'smooth' });

    document.getElementById('bar-home')!.addEventListener('click', () => jumpTo('#home'));
    document.getElementById('bar-projects')!.addEventListener('click', () => window.location.href = '/projects');
    document.getElementById('scroll-hint')!.addEventListener('click', () => jumpTo('#projects'));
</script>

<style is:global>
    @keyframes slideIn {
        from { transform: translateX(-100px); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }

    @keyframes slideInBar {
        from { transform: translateX(-200px); opacity: 0; }
        to { transform: translateX(0); opacity: 1; }
    }

    @keyframes slideUp {
        from { transform: translateY(50px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    #content      { animation: slideIn    0.75s cubic-bezier(0.16, 1, 0.3, 1) 0s     both; }
    #bar-home     { animation: slideInBar 0.75s cubic-bezier(0.16, 1, 0.3, 1) 0.15s  both; }
    #bar-projects { animation: slideInBar 0.75s cubic-bezier(0.16, 1, 0.3, 1) 0.25s  both; }
    #scroll-hint  { animation: slideUp    0.75s cubic-bezier(0.16, 1, 0.3, 1) 0.50s  both; }
</style>
